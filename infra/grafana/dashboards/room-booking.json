{
  "title": "Room Booking Platform",
  "uid": "room-booking",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["room-booking"],
  "panels": [
    {
      "type": "row",
      "title": "HTTP Traffic",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "id": 2,
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "Total req/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "Error Rate (4xx + 5xx)",
      "id": 3,
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[1m]))",
          "legendFormat": "4xx/s"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Latency Percentiles (P50 / P95 / P99)",
      "id": 4,
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "row",
      "title": "Per-Endpoint Breakdown",
      "id": 10,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Top Routes by Request Rate",
      "id": 11,
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sort_desc(sum by (route, method) (rate(http_requests_total[1m])))",
          "legendFormat": "{{method}} {{route}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      }
    },
    {
      "type": "bargauge",
      "title": "P95 Latency per Route",
      "id": 12,
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sort_desc(histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[1m]))))",
          "legendFormat": "{{route}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "row",
      "title": "Business Metrics",
      "id": 20,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Booking Operations",
      "id": 21,
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(bookings_total{outcome=\"created\"}[1m]))",
          "legendFormat": "Created/s"
        },
        {
          "expr": "sum(rate(bookings_total{outcome=\"conflict\"}[1m]))",
          "legendFormat": "Conflicts/s"
        },
        {
          "expr": "sum(rate(bookings_total{outcome=\"cancelled\"}[1m]))",
          "legendFormat": "Cancelled/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "Auth Events",
      "id": 22,
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (operation, result) (rate(auth_operations_total[1m]))",
          "legendFormat": "{{operation}} / {{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "Hold Operations",
      "id": 23,
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(holds_total[1m]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "row",
      "title": "Cache Performance",
      "id": 30,
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "id": 31,
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (cache) (rate(cache_operations_total{status=\"hit\"}[1m])) / (sum by (cache) (rate(cache_operations_total[1m])) > 0)",
          "legendFormat": "{{cache}} hit ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Cache Operations/s",
      "id": 32,
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (cache, status) (rate(cache_operations_total[1m]))",
          "legendFormat": "{{cache}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "row",
      "title": "Node.js Runtime",
      "id": 40,
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Heap Used",
      "id": 41,
      "gridPos": { "x": 0, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (instance) (nodejs_heap_size_used_bytes)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "GC Duration",
      "id": 42,
      "gridPos": { "x": 8, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(nodejs_gc_duration_seconds_sum[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag",
      "id": 43,
      "gridPos": { "x": 16, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (instance) (nodejs_eventloop_lag_seconds)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "type": "row",
      "title": "Logs",
      "id": 50,
      "gridPos": { "x": 0, "y": 45, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "API Logs",
      "id": 51,
      "gridPos": { "x": 0, "y": 46, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{container_name=~\".*api[123].*\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "value": "Prometheus", "text": "Prometheus" },
        "hide": 2
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "value": "Loki", "text": "Loki" },
        "hide": 2
      }
    ]
  }
}
