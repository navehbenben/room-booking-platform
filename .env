# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgres://app:app@localhost:5432/room_booking

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
# REQUIRED — change before deploying (generate with: openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret

# ─────────────────────────────────────────────
# Google OAuth (optional — leave as placeholders to disable Google login)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=dev_placeholder
GOOGLE_CLIENT_SECRET=dev_placeholder
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
FRONTEND_URL=http://localhost:8080

# ─────────────────────────────────────────────
# API server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://localhost:8080

# Unique identifier for this instance (used in logs and /health response)
INSTANCE_ID=api1

# ─────────────────────────────────────────────
# Seed data
# ─────────────────────────────────────────────
# Number of rooms to seed on first boot (default: 250)
SEED_ROOMS_COUNT=500

# ─────────────────────────────────────────────
# Datadog
# ─────────────────────────────────────────────
# DD_API_KEY      — server-side API key (https://app.datadoghq.com/organization-settings/api-keys)
#                   Required for the datadog-agent container (infra metrics + container logs).
#                   Keep secret — never commit this value.
DD_API_KEY=your_datadog_api_key_here

# DD_SITE         — Datadog intake site. Use datadoghq.eu for EU region.
DD_SITE=datadoghq.com

# DD_ENV          — Environment tag attached to all metrics and logs.
DD_ENV=production

# ─── Frontend (Vite) ────────────────────────
# VITE_DD_CLIENT_TOKEN — browser-safe token (https://app.datadoghq.com/organization-settings/client-tokens)
#                        Used by the Browser Logs SDK in apps/web/src/main.tsx.
#                        Safe to include in the browser bundle — it can only SEND logs.
VITE_DD_CLIENT_TOKEN=

# VITE_DD_SITE    — Datadog intake site for the browser SDK (usually matches DD_SITE).
VITE_DD_SITE=datadoghq.com
